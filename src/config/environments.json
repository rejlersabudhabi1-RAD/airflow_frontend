{
  "_comment": "Centralized Environment Configuration for AIFlow",
  "_purpose": "This file aligns frontend, backend, and database configurations using soft-coding technique",
  "_date_created": "2026-03-11",
  "_based_on_commit": "c6c3a7e (9-3-26 : First Commit)",
  
  "environments": {
    "local": {
      "name": "Local Development",
      "description": "Docker Compose local development environment",
      "backend": {
        "url": "http://localhost:8000",
        "api_url": "http://localhost:8000/api/v1",
        "host": "0.0.0.0",
        "port": 8000,
        "debug": true,
        "allowed_hosts": ["localhost", "127.0.0.1", "backend", "backend_local", "aiflow_backend_local", "*"]
      },
      "frontend": {
        "url": "http://localhost:5173",
        "api_proxy": "/api/v1",
        "port": 5173,
        "host": "0.0.0.0"
      },
      "database": {
        "engine": "postgresql",
        "name": "radai_db",
        "user": "postgres",
        "password": "postgres123",
        "host": "db",
        "port": 5432
      },
      "redis": {
        "host": "redis",
        "port": 6379
      }
    },
    
    "dev": {
      "name": "Development (Railway)",
      "description": "Development branch on Railway",
      "backend": {
        "url": "https://aiflow-backend-dev.up.railway.app",
        "api_url": "https://aiflow-backend-dev.up.railway.app/api/v1",
        "host": "0.0.0.0",
        "port": 8000,
        "debug": false,
        "allowed_hosts": ["*"]
      },
      "frontend": {
        "url": "https://aiflow-dev.vercel.app",
        "api_proxy": "https://aiflow-backend-dev.up.railway.app/api/v1",
        "port": 3000,
        "host": "0.0.0.0"
      },
      "database": {
        "use_url": true,
        "url_env_var": "DATABASE_URL"
      },
      "redis": {
        "use_url": true,
        "url_env_var": "REDIS_URL"
      }
    },
    
    "preprod": {
      "name": "Pre-Production (Railway)",
      "description": "Pre-production staging environment on Railway",
      "backend": {
        "url": "https://aiflow-backend-preprod.up.railway.app",
        "api_url": "https://aiflow-backend-preprod.up.railway.app/api/v1",
        "host": "0.0.0.0",
        "port": 8000,
        "debug": false,
        "allowed_hosts": ["*"]
      },
      "frontend": {
        "url": "https://aiflow-preprod.vercel.app",
        "api_proxy": "https://aiflow-backend-preprod.up.railway.app/api/v1",
        "port": 3000,
        "host": "0.0.0.0"
      },
      "database": {
        "use_url": true,
        "url_env_var": "DATABASE_URL"
      },
      "redis": {
        "use_url": true,
        "url_env_var": "REDIS_URL"
      }
    },
    
    "production": {
      "name": "Production (Railway)",
      "description": "Production environment on Railway",
      "backend": {
        "url": "https://aiflow-backend-production.up.railway.app",
        "api_url": "https://aiflow-backend-production.up.railway.app/api/v1",
        "host": "0.0.0.0",
        "port": 8000,
        "debug": false,
        "allowed_hosts": ["*"]
      },
      "frontend": {
        "url": "https://radai.ae",
        "api_proxy": "https://aiflow-backend-production.up.railway.app/api/v1",
        "port": 3000,
        "host": "0.0.0.0"
      },
      "database": {
        "use_url": true,
        "url_env_var": "DATABASE_URL"
      },
      "redis": {
        "use_url": true,
        "url_env_var": "REDIS_URL"
      }
    }
  },
  
  "features": {
    "cors": {
      "enabled": true,
      "allow_credentials": false,
      "allowed_origins": {
        "local": ["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"],
        "dev": ["https://aiflow-dev.vercel.app"],
        "preprod": ["https://aiflow-preprod.vercel.app"],
        "production": ["https://radai.ae", "https://www.radai.ae"]
      }
    },
    "csrf": {
      "enabled": true,
      "trusted_origins": {
        "local": ["http://localhost:5173", "http://127.0.0.1:5173"],
        "dev": ["https://aiflow-dev.vercel.app"],
        "preprod": ["https://aiflow-preprod.vercel.app"],
        "production": ["https://radai.ae", "https://www.radai.ae"]
      }
    },
    "s3_storage": {
      "enabled": true,
      "bucket_prefix": {
        "local": "local-",
        "dev": "dev-",
        "preprod": "preprod-",
        "production": ""
      }
    }
  },
  
  "api": {
    "version": "v1",
    "timeout": 30000,
    "timeout_long": 300000,
    "retry_attempts": 3,
    "retry_delay": 1000
  },
  
  "deployment": {
    "railway": {
      "backend_service": "backend",
      "database_service": "postgres",
      "redis_service": "redis"
    },
    "vercel": {
      "frontend_service": "frontend"
    }
  }
}
