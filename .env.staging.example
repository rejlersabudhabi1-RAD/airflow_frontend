# ============================================
# AIFlow Frontend - STAGING Environment Variables
# ============================================
# Purpose: Pre-Production (Staging) environment
# Deploy to: Vercel (preprod branch)
# Branch: preprod
# ============================================

# ==========================================
# ENVIRONMENT IDENTIFICATION
# ==========================================
VITE_ENVIRONMENT=staging

# ==========================================
# BACKEND API CONFIGURATION
# ==========================================
# Point to Railway staging backend
# Replace with your actual Railway staging URL
VITE_API_URL=https://backend-staging-xxxx.up.railway.app/api/v1

# Alternative if using custom domain:
# VITE_API_URL=https://api-staging.yourdomain.com/api/v1

# ==========================================
# WEBSOCKET CONFIGURATION (if applicable)
# ==========================================
VITE_WS_URL=wss://backend-staging-xxxx.up.railway.app/ws

# ==========================================
# APPLICATION SETTINGS
# ==========================================
# Build mode
NODE_ENV=production

# Application name
VITE_APP_NAME=AIFlow Staging
VITE_APP_VERSION=1.0.0-staging

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable/disable features in staging
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_EXPERIMENTAL_FEATURES=true

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Use test/sandbox credentials for staging

# Google Analytics (optional - use separate tracking ID)
# VITE_GA_TRACKING_ID=G-STAGING-XXXXX

# Sentry (Error tracking - use staging project)
# VITE_SENTRY_DSN=https://xxx@sentry.io/staging-project
# VITE_SENTRY_ENVIRONMENT=staging

# Google Maps API (if used)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Other third-party services
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxx (use test key)
# VITE_MIXPANEL_TOKEN=staging-token

# ==========================================
# AUTHENTICATION
# ==========================================
# OAuth/Social Login (use test app credentials)
# VITE_GOOGLE_CLIENT_ID=staging-client-id.apps.googleusercontent.com
# VITE_FACEBOOK_APP_ID=staging-app-id

# ==========================================
# STORAGE & MEDIA
# ==========================================
# S3 public URL for media files (if needed in frontend)
VITE_MEDIA_URL=https://aiflow-staging-bucket.s3.amazonaws.com/media/

# ==========================================
# UI/UX SETTINGS
# ==========================================
# Show staging indicator banner
VITE_SHOW_STAGING_BANNER=true

# Default language
VITE_DEFAULT_LOCALE=en

# Theme
VITE_DEFAULT_THEME=light

# ==========================================
# PERFORMANCE
# ==========================================
# API request timeout (ms)
VITE_API_TIMEOUT=30000

# Enable mock data for testing (optional)
VITE_USE_MOCK_DATA=false

# ==========================================
# DEPLOYMENT INFO
# ==========================================
# Build date (automatically set by CI/CD)
# VITE_BUILD_DATE=${{VERCEL_BUILD_DATE}}
# VITE_GIT_COMMIT=${{VERCEL_GIT_COMMIT_SHA}}

# ==========================================
# NOTES FOR VERCEL DEPLOYMENT
# ==========================================
# 1. Add these variables in Vercel Dashboard:
#    Settings → Environment Variables
# 
# 2. Select "Preview" environment when adding variables
# 
# 3. Specify the branch: preprod
# 
# 4. All variables must have VITE_ prefix to be exposed to frontend
# 
# 5. Redeploy after adding new environment variables:
#    git commit --allow-empty -m "Trigger redeploy"
#    git push origin preprod
# 
# 6. Verify variables in browser console:
#    console.log(import.meta.env.VITE_API_URL)
# 
# 7. Keep production variables separate - use "Production" environment
